<ui:FluentWindow x:Class="HeartRateMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="PulseStreamer - Monitor Tętna BLE" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#07070A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="PulseStreamer - Monitor Tętna BLE" CloseWindowByDoubleClickOnIcon="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Heart24" Foreground="#FF3B30" Filled="True" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Main Content Grid -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR: Connection and Config -->
            <Grid Grid.Column="0" Width="320" x:Name="LeftPanelGrid" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Scanning Panel -->
                    <RowDefinition Height="*" />    <!-- Scrollable content -->
                </Grid.RowDefinitions>

                <!-- Scanning Card -->
                <ui:Card x:Name="CardScan" Grid.Row="0" Margin="0,0,0,8" Padding="12" Background="#111116" BorderBrush="#1D1D26">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Urządzenia tętna" FontWeight="SemiBold" FontSize="14" Foreground="#f0f0f5" />
                            <TextBlock Text="Włącz opaskę HR, aby rozpocząć" FontSize="11" Foreground="#a0a0b0" Margin="0,2,0,0" />
                            <CheckBox x:Name="CheckAutoConnect" Content="Połącz automatycznie" FontSize="11" Foreground="#a0a0b0" Margin="0,6,0,0" Checked="CheckAutoConnect_Changed" Unchecked="CheckAutoConnect_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:ProgressRing x:Name="ScanProgress" Width="18" Height="18" Margin="0,0,8,0" IsIndeterminate="True" Visibility="Collapsed" />
                            <ui:Button x:Name="BtnScan" Content="Skanuj" Icon="{ui:SymbolIcon Bluetooth24}" Appearance="Primary" Click="BtnScan_Click" Padding="12,6" />
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- Scrollable Sidebar Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- User Profiles Card -->
                        <ui:Card Margin="0,0,0,8" Padding="12" Background="#111116" BorderBrush="#1D1D26">
                            <StackPanel>
                                <TextBlock Text="Profile Użytkowników" FontWeight="SemiBold" FontSize="13" Foreground="#f0f0f5" Margin="0,0,0,10" />
                                
                                <!-- Profiles List -->
                                <ListBox x:Name="ListProfiles" SelectionChanged="ListProfiles_SelectionChanged" Background="Transparent" BorderThickness="0" MaxHeight="140" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <!-- Avatar -->
                                                <Border Width="28" Height="28" CornerRadius="14" Background="{Binding ColorBrush}" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Initial}" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Name -->
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" Foreground="#e0e0e8" FontWeight="SemiBold" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Profile Management Buttons -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button x:Name="BtnAddProfile" Grid.Column="0" Content="Dodaj" Icon="{ui:SymbolIcon Add24}" Appearance="Secondary" Margin="0,0,4,0" Click="BtnAddProfile_Click" Padding="0,6" HorizontalAlignment="Stretch" />
                                    <ui:Button x:Name="BtnDeleteProfile" Grid.Column="1" Content="Usuń" Icon="{ui:SymbolIcon Delete24}" Appearance="Secondary" Margin="4,0,0,0" Click="BtnDeleteProfile_Click" Padding="0,6" HorizontalAlignment="Stretch" />
                                </Grid>

                                <!-- Add Profile Form (Initially Collapsed) -->
                                <StackPanel x:Name="PanelAddProfile" Visibility="Collapsed" Margin="0,10,0,0">
                                    <Border BorderThickness="0,1,0,0" BorderBrush="#252530" Margin="0,0,0,8" />
                                    <TextBlock Text="Nowy Profil" FontWeight="Bold" FontSize="11" Foreground="#a0a0b0" Margin="0,0,0,6" />
                                    
                                    <TextBlock Text="Imię" FontSize="10" Foreground="#a0a0b0" Margin="0,0,0,2" />
                                    <ui:TextBox x:Name="TxtNewProfileName" PlaceholderText="Wpisz imię..." Margin="0,0,0,8" Background="#1c1c24" BorderBrush="#2d2d3b" Foreground="#f0f0f5" />



                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:Button x:Name="BtnSaveNewProfile" Grid.Column="0" Content="Zapisz" Appearance="Primary" Margin="0,0,4,0" Click="BtnSaveNewProfile_Click" Padding="0,6" HorizontalAlignment="Stretch" />
                                        <ui:Button x:Name="BtnCancelNewProfile" Grid.Column="1" Content="Anuluj" Appearance="Secondary" Margin="4,0,0,0" Click="BtnCancelNewProfile_Click" Padding="0,6" HorizontalAlignment="Stretch" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>

                        <!-- History Button -->
                        <ui:Button x:Name="BtnOpenHistory" Content="Historia i Statystyki" Icon="{ui:SymbolIcon History24}" Appearance="Secondary" HorizontalAlignment="Stretch" Click="BtnOpenHistory_Click" Margin="0,0,0,8" Padding="0,10" />

                        <!-- Device List Card -->
                        <ui:Card x:Name="CardDeviceList" Margin="0,0,0,8" Padding="8" Background="#111116" BorderBrush="#1D1D26" MaxHeight="240">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Wykryte opaski HR:" FontSize="12" FontWeight="SemiBold" Margin="4,0,0,6" Foreground="#a0a0b0" />
                                <ListView Grid.Row="1" x:Name="ListDevices" SelectionChanged="ListDevices_SelectionChanged" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#191922" BorderThickness="1" BorderBrush="#252530" CornerRadius="8" Padding="10,8,10,8" Margin="0,0,0,6" HorizontalAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Icon -->
                                                    <ui:SymbolIcon Grid.Column="0" Symbol="Bluetooth24" FontSize="18" Foreground="#0078D4" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" Foreground="#f0f0f5" />
                                                        <TextBlock Text="{Binding AddressString}" FontSize="10" Foreground="#a0a0b0" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <!-- RSSI -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ui:SymbolIcon Symbol="CellularData324" FontSize="14" Foreground="#107C41" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding Rssi}" FontSize="11" FontWeight="SemiBold" Foreground="#e0e0e8"/>
                                                        <TextBlock Text=" dBm" FontSize="10" Foreground="#a0a0b0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </ui:Card>

                        <!-- Status Card -->
                        <ui:Card x:Name="CardStatus" Margin="0,0,0,8" Padding="12" Background="#111116" BorderBrush="#1D1D26" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Stan Połączenia" FontWeight="SemiBold" FontSize="13" Foreground="#f0f0f5" Margin="0,0,0,10" />
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0" Symbol="DeviceEq24" FontSize="16" Foreground="#a0a0b0" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="ElStatusDot" Width="8" Height="8" Fill="#FF3B30" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtStatus" Text="Rozłączony" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#e0e0e8" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0" x:Name="IconBattery" Symbol="Battery1024" FontSize="16" Foreground="#a0a0b0" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="TxtBattery" Text="Bateria: --" VerticalAlignment="Center" Foreground="#e0e0e8" />
                                </Grid>

                                <!-- Extra connection info -->
                                <StackPanel x:Name="PanelConnectionDetails" Visibility="Collapsed" Margin="0,0,0,8">
                                    <Border BorderThickness="0,1,0,0" BorderBrush="#252530" Margin="0,4,0,6" />
                                    
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Urządzenie:" Foreground="#a0a0b0" FontSize="11" />
                                        <TextBlock x:Name="TxtDeviceName" Text="--" Foreground="#e0e0e8" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Sygnał (RSSI):" Foreground="#a0a0b0" FontSize="11" />
                                        <TextBlock x:Name="TxtDeviceRssi" Text="-- dBm" Foreground="#e0e0e8" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Czas połączenia:" Foreground="#a0a0b0" FontSize="11" />
                                        <TextBlock x:Name="TxtConnectionDuration" Text="00:00:00" Foreground="#e0e0e8" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="Zebrane próbki:" Foreground="#a0a0b0" FontSize="11" />
                                        <TextBlock x:Name="TxtPointsCollected" Text="0" Foreground="#e0e0e8" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>

                                <ui:Button x:Name="BtnDisconnect" Content="Rozłącz urządzenie" Icon="{ui:SymbolIcon PlugDisconnected24}" Appearance="Secondary" HorizontalAlignment="Stretch" Click="BtnDisconnect_Click" IsEnabled="False" Padding="0,8" />
                            </StackPanel>
                        </ui:Card>

                        <!-- Settings & User Data Expanders -->
                        <Expander x:Name="ExpanderUserData" Header="Dane Użytkownika" IsExpanded="True" Margin="0,0,0,8" Background="#111116" BorderBrush="#1D1D26" Foreground="#f0f0f5" Expanded="Expander_StateChanged" Collapsed="Expander_StateChanged">
                            <StackPanel Margin="12,8,12,12">
                                <!-- User Age Slider -->
                                <TextBlock Text="Wiek użytkownika (strefy tętna)" FontSize="11" Foreground="#a0a0b0" />
                                <Grid Margin="0,2,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" x:Name="SliderAge" Minimum="10" Maximum="99" Value="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SliderAge_ValueChanged" VerticalAlignment="Center" />
                                    <ui:TextBox Grid.Column="1" Text="{Binding ElementName=SliderAge, Path=Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="8,0,4,0" VerticalAlignment="Center" Width="42" Height="24" Padding="2" TextAlignment="Center" FontWeight="SemiBold" Foreground="#f0f0f5" Background="#1c1c24" BorderBrush="#2d2d3b" />
                                    <TextBlock Grid.Column="2" Text="lat" VerticalAlignment="Center" Foreground="#a0a0b0" FontSize="11" Width="20" />
                                </Grid>

                                <!-- User Gender -->
                                <TextBlock Text="Płeć (kalorie)" FontSize="11" Margin="0,0,0,4" Foreground="#a0a0b0" />
                                <ComboBox x:Name="ComboGender" SelectedIndex="0" Margin="0,0,0,10" SelectionChanged="ComboGender_SelectionChanged" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Mężczyzna" Tag="Male" />
                                    <ComboBoxItem Content="Kobieta" Tag="Female" />
                                </ComboBox>

                                <!-- User Weight Slider -->
                                <TextBlock Text="Waga użytkownika" FontSize="11" Foreground="#a0a0b0" />
                                <Grid Margin="0,2,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" x:Name="SliderWeight" Minimum="40" Maximum="150" Value="75" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="SliderWeight_ValueChanged" VerticalAlignment="Center" />
                                    <ui:TextBox Grid.Column="1" Text="{Binding ElementName=SliderWeight, Path=Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="8,0,4,0" VerticalAlignment="Center" Width="42" Height="24" Padding="2" TextAlignment="Center" FontWeight="SemiBold" Foreground="#f0f0f5" Background="#1c1c24" BorderBrush="#2d2d3b" />
                                    <TextBlock Grid.Column="2" Text="kg" VerticalAlignment="Center" Foreground="#a0a0b0" FontSize="11" Width="20" />
                                </Grid>


                                </StackPanel>
                        </Expander>

                        <Expander x:Name="ExpanderChartSettings" Header="Ustawienia Wykresu" IsExpanded="True" Margin="0,0,0,8" Background="#111116" BorderBrush="#1D1D26" Foreground="#f0f0f5" Expanded="Expander_StateChanged" Collapsed="Expander_StateChanged">
                            <StackPanel Margin="12,8,12,12">
                                <!-- Window Duration -->
                                <TextBlock Text="Okno czasowe" FontSize="11" Foreground="#a0a0b0" />
                                <Grid Margin="0,2,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" x:Name="SliderDuration" Minimum="15" Maximum="300" Value="60" TickFrequency="15" IsSnapToTickEnabled="True" ValueChanged="SliderDuration_ValueChanged" VerticalAlignment="Center" />
                                    <ui:TextBox Grid.Column="1" Text="{Binding ElementName=SliderDuration, Path=Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="8,0,4,0" VerticalAlignment="Center" Width="42" Height="24" Padding="2" TextAlignment="Center" FontWeight="SemiBold" Foreground="#f0f0f5" Background="#1c1c24" BorderBrush="#2d2d3b" />
                                    <TextBlock Grid.Column="2" Text="s" VerticalAlignment="Center" Foreground="#a0a0b0" FontSize="11" Width="20" />
                                </Grid>

                                <!-- Training Goals -->
                                <TextBlock Text="Cel treningowy" FontSize="11" Margin="0,0,0,4" Foreground="#a0a0b0" />
                                <ComboBox x:Name="ComboGoalType" SelectedIndex="0" Margin="0,0,0,8" SelectionChanged="ComboGoalType_SelectionChanged" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Brak" Tag="Brak" />
                                    <ComboBoxItem Content="Kalorie" Tag="Kalorie" />
                                    <ComboBoxItem Content="Czas trwania" Tag="Czas" />
                                </ComboBox>
                                
                                <!-- Goal specific inputs -->
                                <StackPanel x:Name="PanelGoalValue" Visibility="Collapsed" Margin="0,0,0,12">
                                    <TextBlock x:Name="TxtGoalValueLabel" Text="Wartość docelowa" FontSize="11" Foreground="#a0a0b0" />
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" x:Name="SliderGoalValue" Minimum="1" Maximum="1000" Value="100" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SliderGoalValue_ValueChanged" VerticalAlignment="Center" />
                                        <ui:TextBox Grid.Column="1" Text="{Binding ElementName=SliderGoalValue, Path=Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="8,0,4,0" VerticalAlignment="Center" Width="48" Height="24" Padding="2" TextAlignment="Center" FontWeight="SemiBold" Foreground="#f0f0f5" Background="#1c1c24" BorderBrush="#2d2d3b" />
                                        <TextBlock Grid.Column="2" x:Name="TxtGoalUnitLabel" Text="kcal" VerticalAlignment="Center" Foreground="#a0a0b0" FontSize="11" Width="24" />
                                    </Grid>
                                </StackPanel>

                                <!-- Grid Lines Toggle -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Pokazuj siatkę pomocniczą" VerticalAlignment="Center" Foreground="#e0e0e8" FontSize="12" />
                                    <ui:ToggleSwitch x:Name="ToggleGrid" IsChecked="True" Checked="ToggleGrid_Changed" Unchecked="ToggleGrid_Changed" HorizontalAlignment="Right" />
                                </Grid>

                                <!-- Y Axis Autoscaling -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Skala osi Y: Auto" VerticalAlignment="Center" Foreground="#e0e0e8" FontSize="12" />
                                    <ui:ToggleSwitch x:Name="ToggleYScale" IsChecked="True" Checked="ToggleYScale_Changed" Unchecked="ToggleYScale_Changed" HorizontalAlignment="Right" />
                                </Grid>

                                <!-- Manual Y Max Slider -->
                                <Grid Margin="0,0,0,8" x:Name="ManualYGrid" Visibility="Collapsed">
                                    <TextBlock Text="Maks. tętno Y (BPM)" VerticalAlignment="Center" Foreground="#e0e0e8" FontSize="12" />
                                    <Grid HorizontalAlignment="Right" Width="140">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" x:Name="SliderMaxY" Minimum="100" Maximum="220" Value="180" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SliderMaxY_ValueChanged" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding ElementName=SliderMaxY, Path=Value}" Margin="6,0,0,0" VerticalAlignment="Center" Width="24" TextAlignment="Right" FontWeight="SemiBold" Foreground="#f0f0f5" FontSize="11" />
                                    </Grid>
                                </Grid>

                                <!-- Beep Sound -->
                                <Grid Margin="0,0,0,0">
                                    <TextBlock Text="Dźwięk uderzeń (Hospital Beep)" VerticalAlignment="Center" Foreground="#e0e0e8" FontSize="12" />
                                    <ui:ToggleSwitch x:Name="ToggleSound" IsChecked="False" Checked="ToggleSound_Changed" Unchecked="ToggleSound_Changed" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Training Assistant Card -->
                        <Expander x:Name="ExpanderZoneGuard" Header="Asystent Strefy (Zone Guard)" IsExpanded="True" Margin="0,0,0,8" Background="#111116" BorderBrush="#1D1D26" Foreground="#f0f0f5" Expanded="Expander_StateChanged" Collapsed="Expander_StateChanged">
                            <StackPanel Margin="12,8,12,12">
                                
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Włącz asystenta" VerticalAlignment="Center" Foreground="#e0e0e8" FontSize="12" />
                                    <ui:ToggleSwitch x:Name="ToggleZoneGuard" IsChecked="False" Checked="ToggleZoneGuard_Changed" Unchecked="ToggleZoneGuard_Changed" HorizontalAlignment="Right" />
                                </Grid>

                                <TextBlock Text="Strefa docelowa" FontSize="11" Margin="0,0,0,4" Foreground="#a0a0b0" />
                                <ComboBox x:Name="ComboTargetZone" SelectedIndex="2" Margin="0,0,0,8" SelectionChanged="ComboTargetZone_SelectionChanged" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Strefa 1 (Rozgrzewka)" Tag="1" />
                                    <ComboBoxItem Content="Strefa 2 (Spalanie tłuszczu)" Tag="2" />
                                    <ComboBoxItem Content="Strefa 3 (Cardio)" Tag="3" />
                                    <ComboBoxItem Content="Strefa 4 (Próg beztlenowy)" Tag="4" />
                                    <ComboBoxItem Content="Strefa 5 (Ekstremalny wysiłek)" Tag="5" />
                                </ComboBox>

                                <TextBlock Text="Interwał sprawdzania" FontSize="11" Margin="0,0,0,4" Foreground="#a0a0b0" />
                                <ComboBox x:Name="ComboCheckInterval" SelectedIndex="1" Margin="0,0,0,0" SelectionChanged="ComboCheckInterval_SelectionChanged" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Co 15 sekund" Tag="15" />
                                    <ComboBoxItem Content="Co 30 sekund" Tag="30" />
                                    <ComboBoxItem Content="Co 45 sekund" Tag="45" />
                                    <ComboBoxItem Content="Co 1 minutę" Tag="60" />
                                </ComboBox>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- TOGGLE BUTTON -->
            <Grid Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center">
                <ToggleButton x:Name="BtnToggleSidebar" IsChecked="True" Click="BtnToggleSidebar_Click" Background="Transparent" BorderThickness="0" Padding="4">
                    <ui:SymbolIcon Symbol="ChevronLeft24" x:Name="IconToggleSidebar" FontSize="18" Foreground="#a0a0b0" />
                </ToggleButton>
            </Grid>

            <!-- RIGHT PANEL: Dashboard Metrics & Chart -->
            <Grid Grid.Column="2">
                <!-- Live Training Dashboard -->
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Active Session Actions -->
                                <RowDefinition Height="Auto" /> <!-- KPI Cards Row -->
                                <RowDefinition Height="Auto" /> <!-- Goal Progress -->
                                <RowDefinition Height="*" />    <!-- Active Chart Canvas Card -->
                            </Grid.RowDefinitions>

                            <!-- Active Session Actions -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" MinWidth="100" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Nazwa treningu:" VerticalAlignment="Center" Foreground="#a0a0b0" Margin="0,0,8,0" FontSize="12" />
                                <TextBox Grid.Column="1" x:Name="TxtActiveSessionName" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" LostFocus="TxtActiveSessionName_LostFocus" VerticalAlignment="Center" Background="#1c1c24" BorderBrush="#2d2d3b" Foreground="#f0f0f5" Padding="6,4" SelectionBrush="#0078D4" Margin="0,0,12,0" />

                                <ui:Button Grid.Column="2" Content="Eksportuj do CSV" Icon="{ui:SymbolIcon DocumentSave24}" Appearance="Secondary" Click="BtnExportCsvLive_Click" Padding="12,6" />

                                <ComboBox Grid.Column="3" x:Name="ComboActivity" SelectedIndex="0" Margin="0,0,12,0" SelectionChanged="ComboActivity_SelectionChanged" MinWidth="130" MaxWidth="200" VerticalAlignment="Stretch">
                                    <ComboBoxItem Content="Bieżnia" Tag="Bieżnia" />
                                    <ComboBoxItem Content="Aerobik" Tag="Aerobik" />
                                    <ComboBoxItem Content="VR Fitness" Tag="VR Fitness" />
                                    <ComboBoxItem Content="Boks" Tag="Boks" />
                                    <ComboBoxItem Content="Rower stacjonarny" Tag="Rower" />
                                    <ComboBoxItem Content="Inny" Tag="Inny" />
                                </ComboBox>

                                <ui:Button Grid.Column="4" x:Name="BtnTrainingControl" Content="Rozpocznij" Icon="{ui:SymbolIcon Play24}" Appearance="Success" Click="BtnTrainingControl_Click" Padding="12,6" />
                            </Grid>

                            <!-- KPI Cards Row -->
                            <WrapPanel Grid.Row="1" Margin="0,0,0,12" Orientation="Horizontal">
                                <!-- Card 1: Live HR -->
                                <ui:Card Margin="0,0,8,8" MinWidth="150" Padding="12" Background="#151111" BorderBrush="#FF3B30" BorderThickness="1.5,1,1,1">
                                    <Grid>
                                        <ui:SymbolIcon x:Name="IconHeartPulse" Symbol="Heart24" Filled="True" FontSize="50" Foreground="#FF3B30" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0" RenderTransformOrigin="0.5,0.5">
                                            <ui:SymbolIcon.RenderTransform>
                                                <ScaleTransform x:Name="HeartScaleTransform" ScaleX="1.0" ScaleY="1.0" />
                                            </ui:SymbolIcon.RenderTransform>
                                        </ui:SymbolIcon>
                                        <StackPanel>
                                            <TextBlock Text="OSTATNIE TĘTNO" FontSize="9" FontWeight="Bold" Foreground="#e09090"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding LastBpm, TargetNullValue='--', FallbackValue='--'}" FontSize="24" FontWeight="Black" Foreground="#FF3B30" VerticalAlignment="Bottom"/>
                                                <TextBlock Text=" BPM" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,2" Foreground="#e09090" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ZoneString, TargetNullValue='Strefa: --', FallbackValue='Strefa: --'}" FontSize="9" Foreground="#a0a0b0" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>

                                <!-- Card 2: Average BPM -->
                                <ui:Card Margin="0,0,8,8" MinWidth="150" Padding="12" Background="#111316" BorderBrush="#0078D4" BorderThickness="1.5,1,1,1">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="Heart24" Filled="False" FontSize="50" Foreground="#0078D4" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0"/>
                                        <StackPanel>
                                            <TextBlock Text="ŚREDNIE TĘTNO" FontSize="9" FontWeight="Bold" Foreground="#90b5e0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding AverageBpm, TargetNullValue='--', FallbackValue='--'}" FontSize="24" FontWeight="Bold" Foreground="#0078D4" VerticalAlignment="Bottom"/>
                                                <TextBlock Text=" BPM" FontSize="11" Margin="2,0,0,2" Foreground="#90b5e0" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>

                                <!-- Card 3: Min / Max BPM -->
                                <ui:Card Margin="0,0,8,8" MinWidth="150" Padding="12" Background="#131116" BorderBrush="#A020F0" BorderThickness="1.5,1,1,1">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="ArrowSort24" FontSize="50" Foreground="#A020F0" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0"/>
                                        <StackPanel>
                                            <TextBlock Text="MIN / MAX TĘTNO" FontSize="9" FontWeight="Bold" Foreground="#c690e0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding MinMaxString, TargetNullValue='-- / --', FallbackValue='-- / --'}" FontSize="20" FontWeight="Bold" Foreground="#A020F0" VerticalAlignment="Bottom"/>
                                                <TextBlock Text=" BPM" FontSize="11" Margin="2,0,0,1" Foreground="#c690e0" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>

                                <!-- Card 4: Monitoring Duration -->
                                <ui:Card Margin="0,0,8,8" MinWidth="150" Padding="12" Background="#111512" BorderBrush="#107C41" BorderThickness="1.5,1,1,1">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="Timer24" FontSize="50" Foreground="#107C41" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0"/>
                                        <StackPanel>
                                            <TextBlock Text="CZAS MONITOROWANIA" FontSize="9" FontWeight="Bold" Foreground="#90e0a5"/>
                                            <TextBlock Text="{Binding DurationString, TargetNullValue='00:00:00', FallbackValue='00:00:00'}" FontSize="20" FontWeight="Bold" Foreground="#107C41" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>

                                <!-- Card 5: Calories Burned -->
                                <ui:Card Margin="0,0,0,8" MinWidth="150" Padding="12" Background="#161511" BorderBrush="#D89B00" BorderThickness="1.5,1,1,1">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="Fire24" FontSize="50" Foreground="#D89B00" Opacity="0.1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0"/>
                                        <StackPanel>
                                            <TextBlock Text="SPALONE KALORIE" FontSize="9" FontWeight="Bold" Foreground="#e0c690"/>
                                            <TextBlock Text="{Binding CaloriesBurnedText, TargetNullValue='0 kcal', FallbackValue='0 kcal'}" FontSize="20" FontWeight="Bold" Foreground="#D89B00" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </WrapPanel>

                            <!-- Goal Progress Card -->
                            <ui:Card x:Name="CardGoalProgress" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,12" Padding="12" Background="#111116" BorderBrush="#1D1D26">
                                <StackPanel>
                                    <TextBlock x:Name="TxtGoalTitle" Text="POSTĘP CELU" FontSize="9" FontWeight="Bold" Foreground="#a0a0b0" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="ProgressGoal" Minimum="0" Maximum="100" Value="0" Height="12" Foreground="#0078D4" Background="#1c1c24" BorderThickness="0" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TxtGoalStatus" Text="0% (0 / 100)" FontSize="11" Foreground="#f0f0f5" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </ui:Card>

                            <!-- Real-time Chart Card -->
                            <ui:Card Grid.Row="3" Margin="0" Padding="16" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="#111116" BorderBrush="#1D1D26" MinHeight="400" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Kardiogram w czasie rzeczywistym" FontSize="16" FontWeight="SemiBold" Foreground="#f0f0f5" />
                                            <TextBlock Text="Wykres prezentuje tętno (BPM) w relacji do czasu (sekundy sesji)" FontSize="12" Foreground="#a0a0b0" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Canvas Grid.Row="1" x:Name="ChartCanvasLive" ClipToBounds="True" Background="#0C0C12" SizeChanged="ChartCanvasLive_SizeChanged" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
                                </Grid>
                            </ui:Card>
                        </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
